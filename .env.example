# ═══════════════════════════════════════════════════════════════
# VIGIL — Healthcare Financial Guardian
# Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to git. Only .env.example is tracked.
# ═══════════════════════════════════════════════════════════════

# ── Google Gemini (REQUIRED) ──────────────────────────────────
# Used for: multimodal receipt OCR, agent reasoning
# Get key: https://aistudio.google.com/apikey
# Free tier: 15 RPM on Gemini 2.5 Pro (sufficient for demo)
GOOGLE_API_KEY=

# ── Moorcheh (REQUIRED) ──────────────────────────────────────
# Used for: 3-namespace memory (episodic, semantic, providers)
# Get key: https://moorcheh.ai (sign up, generate API key)
# Namespaces are created automatically on first use
MOORCHEH_API_KEY=

# ── Snowflake (REQUIRED) ─────────────────────────────────────
# Used for: structured data warehouse (claims, fee guide, audit)
# Free trial: https://signup.snowflake.com (120-day student trial)
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_DATABASE=VIGIL
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_ROLE=ACCOUNTADMIN

# ── IBM watsonx.ai (OPTIONAL) ────────────────────────────────
# Used for: compliance gate (fraud flag validation, bias check)
# Get key: https://cloud.ibm.com (free tier available)
# If absent, falls back to local keyword safety filter
WATSONX_API_KEY=
WATSONX_PROJECT_ID=
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# ── Application Settings ─────────────────────────────────────
# Backend server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=["http://localhost:3000"]

# Logging
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR

# ── Demo & Feature Flags ─────────────────────────────────────
# Demo mode: uses synthetic student profiles and pre-seeded data
DEMO_MODE=true

# Toggle IBM watsonx.ai compliance gate
# Set to false to use local keyword safety filter instead
ENABLE_WATSONX=true

# Toggle reflection layer (stretch goal, disable if behind schedule)
ENABLE_REFLECTION=false

# Toggle WebSocket real-time streaming
# Set to false to fall back to polling
ENABLE_WEBSOCKET=true

# ── Fraud Policy Overrides (optional) ────────────────────────
# These override values in fraud_policy.yaml at runtime
# Useful for demo tuning without editing YAML
FRAUD_SCORE_THRESHOLD_ELEVATED=26
FRAUD_SCORE_THRESHOLD_HIGH=51
FRAUD_SCORE_THRESHOLD_CRITICAL=76
FEE_DEVIATION_TOLERANCE_DEFAULT=0.30
FEE_DEVIATION_TOLERANCE_HIGH_RISK=0.15

# ── Default Demo Student (optional) ──────────────────────────
# Pre-selects this student profile on the upload page
DEFAULT_STUDENT_ID=STU_PRIYA_001
