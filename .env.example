# ══════════════════════════════════════════════════════════════
# VIGIL — Healthcare Financial Guardian
# Environment Configuration
# ══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit the real .env file. It is in .gitignore.
# ══════════════════════════════════════════════════════════════

# ── Google Gemini (REQUIRED) ──
# Used by: OCR Agent, Fraud Analyst, Health Extractor, Report Drafter
# Get a key: https://aistudio.google.com/app/apikey
# Free tier: 15 requests/minute on Gemini 2.5 Pro
GOOGLE_API_KEY=

# ── Moorcheh (REQUIRED) ──
# Used by: History Enricher, Health Extractor, Benefits Navigator, Lesson Extractor
# 3 namespaces: episodic (claim history), semantic (fee guide + plan docs), providers (risk stats)
# Get a key: https://docs.moorcheh.ai
MOORCHEH_API_KEY=

# ── Snowflake (REQUIRED) ──
# Used by: Persister, Fraud Analyst (fee guide queries), Audit Logger, all read operations
# Tables: students, claims, providers, fee_guide, fraud_cases, action_plans, benefits_reports, plan_coverage, audit_log
# Free student trial: https://signup.snowflake.com/
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_DATABASE=VIGIL
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_ROLE=ACCOUNTADMIN

# ── IBM watsonx.ai (OPTIONAL, recommended) ──
# Used by: Compliance Gate (fraud flag validation, bias detection, explainability)
# If not set, falls back to local keyword safety filter
# Get a key: https://cloud.ibm.com/catalog/services/watson-machine-learning
WATSONX_API_KEY=
WATSONX_PROJECT_ID=
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# ══════════════════════════════════════════════════════════════
# APP CONFIGURATION
# ══════════════════════════════════════════════════════════════

# ── Server ──
BACKEND_PORT=8000
FRONTEND_PORT=3000
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=["http://localhost:3000"]

# ── Logging ──
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ── Demo Mode ──
# When true: uses synthetic student profiles and pre-seeded data
# When false: expects real data (not recommended for hackathon)
DEMO_MODE=true

# ══════════════════════════════════════════════════════════════
# FEATURE FLAGS
# ══════════════════════════════════════════════════════════════
# Toggle features on/off without code changes.
# Useful for graceful degradation if an API is down.

# IBM watsonx.ai Compliance Gate
# If false: skips watsonx validation, uses local keyword safety filter
ENABLE_WATSONX=true

# Reflection Layer (Outcome Evaluator + Lesson Extractor)
# Stretch goal. Set to false if behind schedule.
ENABLE_REFLECTION=false

# WebSocket real-time streaming
# If false: frontend polls for results instead of streaming
ENABLE_WEBSOCKET=true

# ══════════════════════════════════════════════════════════════
# FRAUD POLICY OVERRIDES (optional)
# ══════════════════════════════════════════════════════════════
# These override values in agents/reasoning/fraud_policy.yaml
# Useful for quick tuning without editing YAML

# Fraud score thresholds (0-100)
FRAUD_THRESHOLD_ELEVATED=26
FRAUD_THRESHOLD_HIGH=51
FRAUD_THRESHOLD_CRITICAL=76

# Default fee deviation tolerance (percentage above ODA guide)
# 0.30 = 30% above suggested fee is considered normal variance
FEE_DEVIATION_TOLERANCE=0.30

# High-risk code tolerance (stricter for commonly upcoded procedures)
# 0.15 = only 15% above suggested fee before flagging
HIGH_RISK_FEE_TOLERANCE=0.15

# ══════════════════════════════════════════════════════════════
# DEMO STUDENT (for quick testing)
# ══════════════════════════════════════════════════════════════
# Default student profile loaded on app start
DEFAULT_STUDENT_ID=STU_PRIYA_001
DEFAULT_STUDENT_PLAN=UTSU_2025
